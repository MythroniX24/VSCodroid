<?xml version="1.0" encoding="utf-8"?>
<!--
    Main editor layout.

    Dark background on every layer prevents white flash:
      Window background  →  #1e1e1e (themes.xml windowBackground)
      FrameLayout        →  #1e1e1e (below)
      WebView            →  #1e1e1e (VSCodroidWebView.configure setBackgroundColor)

    All three must be dark. If any layer is missing, a white flash appears for
    the 5-30 seconds it takes VS Code's CSS to apply its dark theme after load.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/webViewContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!--
        VSCodroidWebViewComponent adds:
          • Long press (550ms) → contextmenu event (right-click simulation)
          • Forced soft-keyboard show on editable tap (Monaco hidden-textarea fix)
        Native pinch-to-zoom is enabled via WebSettings in VSCodroidWebView.configure().
        Dark background applied via the android:background attribute below.
    -->
    <com.vscodroid.webview.VSCodroidWebViewComponent
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground" />

    <!--
        Extra key row: Tab, Esc, Ctrl, Alt, arrows, brackets etc.
        Visibility managed by MainActivity based on IME insets.
    -->
    <com.vscodroid.keyboard.ExtraKeyRow
        android:id="@+id/extraKeyRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:visibility="gone" />

    <!--
        Temporary on-device debug console — a small floating "LOG" toggle that
        expands into a console showing JS console.log/warn/error output (incl.
        errors our injected scripts' try/catch blocks would otherwise swallow
        silently) plus direct Kotlin-side diagnostic lines. Added LAST so it
        renders on top of everything else; only its own small button/panel
        consume touches, the WebView underneath is unaffected. Only shown in
        debuggable builds (gated in MainActivity via Logger.debugEnabled).
    -->
    <com.vscodroid.debug.DebugConsoleOverlay
        android:id="@+id/debugConsole"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
